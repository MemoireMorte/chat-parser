# Twitch OAuth application credentials
# Create an app at https://dev.twitch.tv/console/apps
PUBLIC_TWITCH_CLIENT_ID=your_twitch_client_id
PUBLIC_TWITCH_REDIRECT_URI=http://localhost:5173

# Discord webhook URL for posting detected chat URLs
# Create one in your Discord server: Channel Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
